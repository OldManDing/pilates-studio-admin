# ============================================
# Pilates Studio Admin Frontend - Environment Variables
# ============================================

# API Base URL (backend)
# No trailing slash
API_BASE_URL=https://api.yourdomain.com/api

# Public Path (for CDN deployment)
PUBLIC_PATH=/

# Build Output
OUTPUT_DIR=dist

# Bundle Analyze (set to true to analyze bundle size)
ANALYZE=false

# Development Only
PORT=8000
MOCK=false
