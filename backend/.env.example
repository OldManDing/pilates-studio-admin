# ============================================
# Pilates Studio Backend - Environment Variables
# ============================================

# Application
NODE_ENV=development
PORT=3000
APP_NAME=pilates-studio-backend
API_PREFIX=api

# Database (MySQL)
# Format: mysql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=mysql://root:password@127.0.0.1:3306/pilates_studio

# JWT Authentication
# IMPORTANT: Replace with strong secrets in production (min 32 chars)
# Generate: openssl rand -base64 32
JWT_ACCESS_SECRET=replace-with-strong-access-secret-min-32-chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=replace-with-strong-refresh-secret-min-32-chars
JWT_REFRESH_EXPIRES_IN=7d

# Security
BCRYPT_ROUNDS=10

# CORS (comma-separated origins, or * for all - not recommended for production)
CORS_ORIGINS=*

# Logging
# Levels: debug, verbose, log, warn, error
LOG_LEVEL=log

# Rate Limiting (requests per window)
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# File Upload (optional)
UPLOAD_MAX_FILE_SIZE=5242880
UPLOAD_DEST=./uploads

# WeChat Mini Program (optional, for mini user auth)
WECHAT_APPID=
WECHAT_SECRET=
WECHAT_TEMPLATE_ID_BOOKING_CONFIRMATION=
WECHAT_TEMPLATE_ID_BOOKING_CANCELLED=
WECHAT_TEMPLATE_ID_BOOKING_REMINDER=
WECHAT_TEMPLATE_ID_ATTENDANCE_CHECKED_IN=
WECHAT_TEMPLATE_ID_MEMBERSHIP_EXPIRY=

# Email (optional, for notification delivery)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=

# Notifications
NOTIFICATION_EXPIRY_REMINDER_DAYS=3
NOTIFICATION_BOOKING_REMINDER_MINUTES=60
NOTIFICATION_PROCESSING_BATCH_SIZE=50

# Seed Data (first admin user)
SEED_ADMIN_EMAIL=owner@pilates.com
SEED_ADMIN_PASSWORD=Passw0rd!
