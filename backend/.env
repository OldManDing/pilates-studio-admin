# ============================================
# Pilates Studio Backend - Environment
# ============================================

# Application
NODE_ENV=development
PORT=3000
APP_NAME=pilates-studio-backend
API_PREFIX=api

# Database (MySQL)
# 请根据你的 MySQL 配置修改
DATABASE_URL=mysql://root:root@localhost:3307/pilates_studio

# JWT Authentication
JWT_ACCESS_SECRET=your-super-secret-access-key-minimum-32-characters
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=your-super-secret-refresh-key-minimum-32-characters
JWT_REFRESH_EXPIRES_IN=7d

# Security
BCRYPT_ROUNDS=10

# CORS
CORS_ORIGINS=*

# Logging
LOG_LEVEL=log

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Seed Data (首次运行创建管理员)
SEED_ADMIN_EMAIL=admin@pilates.com
SEED_ADMIN_PASSWORD=Admin123!
