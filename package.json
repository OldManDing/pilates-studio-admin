{
  "name": "pilates-studio-admin",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "umi dev",
    "build": "umi build",
    "typecheck": "tsc --noEmit",
    "smoke-test": "vitest run smoke-tests",
    "smoke-test:watch": "vitest smoke-tests",
    "smoke-test:cov": "vitest run smoke-tests --coverage",
    "lint": "eslint src config --ext .js,.jsx,.ts,.tsx",
    "lint:fix": "eslint src config --ext .js,.jsx,.ts,.tsx --fix",
    "format": "prettier --check package.json .eslintrc.cjs .prettierrc.json",
    "format:write": "prettier --write package.json .eslintrc.cjs .prettierrc.json"
  },
  "dependencies": {
    "@ant-design/icons": "^5.6.1",
    "antd": "^5.27.1",
    "dayjs": "^1.11.13",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "recharts": "^2.15.3",
    "umi": "^4.4.6"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "@typescript-eslint/visitor-keys": "^7.18.0",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^4.6.2",
    "eslint-plugin-unused-imports": "^3.2.0",
    "jsdom": "^29.0.2",
    "prettier": "^3.3.3",
    "typescript": "^5.7.2",
    "vitest": "^4.1.4"
  }
}
